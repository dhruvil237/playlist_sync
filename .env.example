# Spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# YouTube Music OAuth (recommended — token auto-refreshes)
# Create a project at https://console.cloud.google.com, enable YouTube Data API v3,
# create OAuth credentials (type: "TVs and Limited Input"), then paste here.
# If not set, auth falls back to browser-headers (paste from DevTools).
# YTMUSIC_CLIENT_ID=your_google_client_id_here
# YTMUSIC_CLIENT_SECRET=your_google_client_secret_here

# AI matching — any OpenAI-compatible provider
# OpenAI (default):
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4o-mini

# Ollama (local, no key needed):
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3

# Groq:
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=your_groq_api_key_here
# AI_MODEL=llama-3.3-70b-versatile

# Together AI:
# AI_BASE_URL=https://api.together.xyz/v1
# AI_API_KEY=your_together_api_key_here
# AI_MODEL=meta-llama/Llama-3-8b-chat-hf

# Web dashboard (optional)
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765
